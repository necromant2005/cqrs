{
  "name": "test-assignment/sqrs",
  "description": "Billing API module with lightweight Event Sourcing and CQRS.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "ext-redis": "*",
    "doctrine/dbal": "^4.3",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.5",
    "symfony/console": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/flex": "^2.7",
    "symfony/framework-bundle": "^8.0",
    "symfony/messenger": "^8.0",
    "symfony/redis-messenger": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/serializer": "^8.0",
    "symfony/uid": "^8.0",
    "symfony/validator": "^8.0",
    "symfony/yaml": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "symfony/browser-kit": "^8.0",
    "symfony/css-selector": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "extra": {
    "symfony": {
      "require": "8.0.*",
      "allow-contrib": false
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  }
}
